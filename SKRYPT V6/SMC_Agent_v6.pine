//@version=6
// Backtest mode is intentionally bar-close only. For live scalping, clone this script and enable calc_on_every_tick=true.
// If buffer errors persist on heavy crypto symbols, increase max_bars_back to 1000.
strategy("SMC Autonomous Agent v6", overlay=true, calc_on_every_tick=false, process_orders_on_close=true, max_lines_count=500, max_labels_count=500, max_boxes_count=250, max_polylines_count=50, max_bars_back=500)

// =========================
// Enums
// =========================
enum AgentPhase
    Perception
    Reasoning
    Planning
    Execution

enum TrendState
    Bullish
    Bearish
    Neutral

enum AgentStatus
    Idle
    Armed
    InPosition
    Cooldown

enum Direction
    Long
    Short
    Flat

enum SignalGrade
    None
    B
    A

enum PatternType
    None
    BullFlag
    BearFlag
    HeadShoulders
    TriangleBull
    TriangleBear
    InvHeadShoulders
    DoubleTop
    DoubleBottom
    TripleTop
    TripleBottom
    TriangleAscending
    TriangleDescending
    WedgeBullish
    WedgeBearish
    WedgeFalling
    WedgeRising
    WedgeFallingCont
    WedgeRisingCont
    BullPennant
    BearPennant
    CupHandle
    ChannelRising
    ChannelFalling
    RoundingBottom
    RoundingTop
    DiamondTop

// =========================
// Localization
// =========================
string lang = input.string("UA", "Мова", options=["UA", "EN", "PL"])

f_txt(string key, string language) =>
    switch language
        "UA" =>
            switch key
                "phase" => "Фаза"
                "trend" => "Тренд"
                "status" => "Статус"
                "ob" => "Ордер-блок"
                "liq" => "Ліквідність"
                "rr" => "RR"
                "dir" => "Напрям"
                "grade" => "Клас"
                "bars" => "Барів до TP1"
                "slbars" => "Барів до SL"
                "signalA" => "Сигнал A"
                "signalB" => "Сигнал B"
                "none" => "Нема"
                "pattern" => "Патерн"
                "prob" => "Ймовірність"
                "timetotarget" => "Час до цілі"
                => key
        "PL" =>
            switch key
                "phase" => "Faza"
                "trend" => "Trend"
                "status" => "Status"
                "ob" => "Order Block"
                "liq" => "Płynność"
                "rr" => "RR"
                "dir" => "Kierunek"
                "grade" => "Klasa"
                "bars" => "Świece do TP1"
                "slbars" => "Świece do SL"
                "signalA" => "Sygnał A"
                "signalB" => "Sygnał B"
                "none" => "Brak"
                "pattern" => "Formacja"
                "prob" => "Prawdopodobieństwo"
                "timetotarget" => "Czas do celu"
                => key
        =>
            switch key
                "phase" => "Phase"
                "trend" => "Trend"
                "status" => "Status"
                "ob" => "Order Block"
                "liq" => "Liquidity"
                "rr" => "RR"
                "dir" => "Direction"
                "grade" => "Grade"
                "bars" => "Bars to TP1"
                "slbars" => "Bars to SL"
                "signalA" => "Signal A"
                "signalB" => "Signal B"
                "none" => "None"
                "pattern" => "Pattern"
                "prob" => "Probability"
                "timetotarget" => "Time to target"
                => key

f_patternName(PatternType pType) =>
    switch pType
        PatternType.BullFlag           => "Бичачий прапор"
        PatternType.BearFlag           => "Ведмежий прапор"
        PatternType.HeadShoulders      => "Голова і плечі"
        PatternType.TriangleBull       => "Бичачий трикутник"
        PatternType.TriangleBear       => "Ведмежий трикутник"
        PatternType.InvHeadShoulders   => "Перевернена Г і П"
        PatternType.DoubleTop          => "Подвійна вершина"
        PatternType.DoubleBottom       => "Подвійне дно"
        PatternType.TripleTop          => "Потрійна вершина"
        PatternType.TripleBottom       => "Потрійне дно"
        PatternType.TriangleAscending  => "Висхідний трикутник"
        PatternType.TriangleDescending => "Спадний трикутник"
        PatternType.WedgeBullish       => "Бичачий клин"
        PatternType.WedgeBearish       => "Ведмежий клин"
        PatternType.WedgeFalling       => "Спадний клин (розворот)"
        PatternType.WedgeRising        => "Висхідний клин (розворот)"
        PatternType.WedgeFallingCont   => "Спадний клин (продовження)"
        PatternType.WedgeRisingCont    => "Висхідний клин (продовження)"
        PatternType.BullPennant        => "Бичачий вимпел"
        PatternType.BearPennant        => "Ведмежий вимпел"
        PatternType.CupHandle          => "Чаша з ручкою"
        PatternType.ChannelRising      => "Висхідний канал"
        PatternType.ChannelFalling     => "Спадний канал"
        PatternType.RoundingBottom     => "Закруглене дно"
        PatternType.RoundingTop        => "Закруглена вершина"
        PatternType.DiamondTop         => "Ромб на вершині"
        => "Нема"

f_contextKey(PatternType pType, bool sweptHigh, bool sweptLow, TrendState trend, bool rsOk, bool imbOk, bool pocLongOk, bool pocShortOk, string sessionTag) =>
    string liqTag = sweptHigh ? "SweepHigh" : sweptLow ? "SweepLow" : "NoSweep"
    string pocTag = pocLongOk ? "POCAbove" : pocShortOk ? "POCBelow" : "POCMid"
    f_patternName(pType) + "|" + liqTag + "|" + str.tostring(trend) + "|" + (rsOk ? "RS+" : "RS-") + "|" + (imbOk ? "Imb+" : "Imb-") + "|" + pocTag + "|" + sessionTag

